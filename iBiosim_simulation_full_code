<?xml version="1.0" encoding="UTF-8"?>
<sbml xmlns="http://www.sbml.org/sbml/level3/version1/core" level="3" version="1">
  <model id="nora_ecosystem" name="Nora Ecosystem Faithful SBML">

    <listOfCompartments>
      <compartment id="cell" size="1" constant="true"/>
    </listOfCompartments>

    <listOfSpecies>
      <species id="EsL"     compartment="cell" initialAmount="0.3" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="EsK"     compartment="cell" initialAmount="0.3" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="EsTrp"   compartment="cell" initialAmount="0.3" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="EsHis"   compartment="cell" initialAmount="0.3" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="ProdLyc" compartment="cell" initialAmount="0.2" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="ProdIso" compartment="cell" initialAmount="0.2" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="ProdNar" compartment="cell" initialAmount="0.2" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="ProdMal" compartment="cell" initialAmount="0.2" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="NitroA"  compartment="cell" initialAmount="0.3" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="NitroB"  compartment="cell" initialAmount="0.3" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="Pseudo"  compartment="cell" initialAmount="0.3" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="Para"    compartment="cell" initialAmount="0.3" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="GeoA"    compartment="cell" initialAmount="0.3" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="GeoB"    compartment="cell" initialAmount="0.3" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="LuxR"    compartment="cell" initialAmount="0.2" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="LuxS"    compartment="cell" initialAmount="0.2" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="lys"     compartment="cell" initialAmount="1"   hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="leu"     compartment="cell" initialAmount="1"   hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="trp"     compartment="cell" initialAmount="1"   hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="his"     compartment="cell" initialAmount="1"   hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="lyc"     compartment="cell" initialAmount="0"   hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="iso"     compartment="cell" initialAmount="0"   hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="nar"     compartment="cell" initialAmount="0"   hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="mal"     compartment="cell" initialAmount="0"   hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="nh3"     compartment="cell" initialAmount="5"   hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="no2"     compartment="cell" initialAmount="0"   hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="no3"     compartment="cell" initialAmount="0"   hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="e"       compartment="cell" initialAmount="0"   hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="AHL"     compartment="cell" initialAmount="0"   hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="AI2"     compartment="cell" initialAmount="0"   hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
    </listOfSpecies>

    <listOfParameters>
      <parameter id="mu"    value="0.8" constant="true"/>
      <parameter id="K"     value="0.5" constant="true"/>
      <parameter id="d"     value="0.1" constant="true"/>
      <parameter id="K_pop" value="10"  constant="true"/>
    </listOfParameters>

    <listOfReactions>

      <!-- ========== E. coli cross-feeding growth (Monod x logistic) ========== -->
      <reaction id="r_EsL_grow" reversible="false" fast="false">
        <listOfProducts><speciesReference species="EsL" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/>
            <ci>mu</ci>
            <apply><divide/><ci>lys</ci><apply><plus/><ci>K</ci><ci>lys</ci></apply></apply>
            <ci>EsL</ci>
            <apply><minus/><cn>1</cn><apply><divide/><ci>EsL</ci><ci>K_pop</ci></apply></apply>
          </apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_EsK_grow" reversible="false" fast="false">
        <listOfProducts><speciesReference species="EsK" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/>
            <ci>mu</ci>
            <apply><divide/><ci>leu</ci><apply><plus/><ci>K</ci><ci>leu</ci></apply></apply>
            <ci>EsK</ci>
            <apply><minus/><cn>1</cn><apply><divide/><ci>EsK</ci><ci>K_pop</ci></apply></apply>
          </apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_EsTrp_grow" reversible="false" fast="false">
        <listOfProducts><speciesReference species="EsTrp" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/>
            <ci>mu</ci>
            <apply><divide/><ci>trp</ci><apply><plus/><ci>K</ci><ci>trp</ci></apply></apply>
            <ci>EsTrp</ci>
            <apply><minus/><cn>1</cn><apply><divide/><ci>EsTrp</ci><ci>K_pop</ci></apply></apply>
          </apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_EsHis_grow" reversible="false" fast="false">
        <listOfProducts><speciesReference species="EsHis" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/>
            <ci>mu</ci>
            <apply><divide/><ci>his</ci><apply><plus/><ci>K</ci><ci>his</ci></apply></apply>
            <ci>EsHis</ci>
            <apply><minus/><cn>1</cn><apply><divide/><ci>EsHis</ci><ci>K_pop</ci></apply></apply>
          </apply>
        </math></kineticLaw>
      </reaction>

      <!-- ========== Metabolite dynamics for cross-feeding ========== -->
      <!-- dlys/dt = 0.5*EsK - 0.4*EsL - 0.1*lys -->
      <reaction id="r_lys_prod_EsK" reversible="false" fast="false">
        <listOfProducts><speciesReference species="lys" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.5</cn><ci>EsK</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_lys_cons_EsL" reversible="false" fast="false">
        <listOfReactants><speciesReference species="lys" stoichiometry="1" constant="true"/></listOfReactants>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.4</cn><ci>EsL</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_lys_decay" reversible="false" fast="false">
        <listOfReactants><speciesReference species="lys" stoichiometry="1" constant="true"/></listOfReactants>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.1</cn><ci>lys</ci></apply>
        </math></kineticLaw>
      </reaction>

      <!-- dleu/dt = 0.5*EsL - 0.4*EsK - 0.1*leu -->
      <reaction id="r_leu_prod_EsL" reversible="false" fast="false">
        <listOfProducts><speciesReference species="leu" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.5</cn><ci>EsL</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_leu_cons_EsK" reversible="false" fast="false">
        <listOfReactants><speciesReference species="leu" stoichiometry="1" constant="true"/></listOfReactants>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.4</cn><ci>EsK</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_leu_decay" reversible="false" fast="false">
        <listOfReactants><speciesReference species="leu" stoichiometry="1" constant="true"/></listOfReactants>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.1</cn><ci>leu</ci></apply>
        </math></kineticLaw>
      </reaction>

      <!-- dtrp/dt = 0.4*EsHis - 0.3*EsTrp - 0.1*trp -->
      <reaction id="r_trp_prod_EsHis" reversible="false" fast="false">
        <listOfProducts><speciesReference species="trp" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.4</cn><ci>EsHis</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_trp_cons_EsTrp" reversible="false" fast="false">
        <listOfReactants><speciesReference species="trp" stoichiometry="1" constant="true"/></listOfReactants>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.3</cn><ci>EsTrp</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_trp_decay" reversible="false" fast="false">
        <listOfReactants><speciesReference species="trp" stoichiometry="1" constant="true"/></listOfReactants>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.1</cn><ci>trp</ci></apply>
        </math></kineticLaw>
      </reaction>

      <!-- dhis/dt = 0.4*EsTrp - 0.3*EsHis - 0.1*his -->
      <reaction id="r_his_prod_EsTrp" reversible="false" fast="false">
        <listOfProducts><speciesReference species="his" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.4</cn><ci>EsTrp</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_his_cons_EsHis" reversible="false" fast="false">
        <listOfReactants><speciesReference species="his" stoichiometry="1" constant="true"/></listOfReactants>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.3</cn><ci>EsHis</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_his_decay" reversible="false" fast="false">
        <listOfReactants><speciesReference species="his" stoichiometry="1" constant="true"/></listOfReactants>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.1</cn><ci>his</ci></apply>
        </math></kineticLaw>
      </reaction>

      <!-- ========== Production strains ========== -->
      <reaction id="r_ProdLyc_grow" reversible="false" fast="false">
        <listOfProducts><speciesReference species="ProdLyc" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/>
            <ci>mu</ci><ci>ProdLyc</ci>
            <apply><minus/><cn>1</cn><apply><divide/><ci>ProdLyc</ci><ci>K_pop</ci></apply></apply>
          </apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_ProdIso_grow" reversible="false" fast="false">
        <listOfProducts><speciesReference species="ProdIso" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/>
            <ci>mu</ci><ci>ProdIso</ci>
            <apply><minus/><cn>1</cn><apply><divide/><ci>ProdIso</ci><ci>K_pop</ci></apply></apply>
          </apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_ProdNar_grow" reversible="false" fast="false">
        <listOfProducts><speciesReference species="ProdNar" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/>
            <ci>mu</ci><ci>ProdNar</ci>
            <apply><minus/><cn>1</cn><apply><divide/><ci>ProdNar</ci><ci>K_pop</ci></apply></apply>
          </apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_ProdMal_grow" reversible="false" fast="false">
        <listOfProducts><speciesReference species="ProdMal" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/>
            <ci>mu</ci><ci>ProdMal</ci>
            <apply><minus/><cn>1</cn><apply><divide/><ci>ProdMal</ci><ci>K_pop</ci></apply></apply>
          </apply>
        </math></kineticLaw>
      </reaction>

      <!-- Product metabolite dynamics (dlyc/dt = 0.6*ProdLyc - 0.1*lyc etc) -->
      <reaction id="r_lyc_prod" reversible="false" fast="false">
        <listOfProducts><speciesReference species="lyc" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.6</cn><ci>ProdLyc</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_lyc_decay" reversible="false" fast="false">
        <listOfReactants><speciesReference species="lyc" stoichiometry="1" constant="true"/></listOfReactants>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.1</cn><ci>lyc</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_iso_prod" reversible="false" fast="false">
        <listOfProducts><speciesReference species="iso" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.6</cn><ci>ProdIso</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_iso_decay" reversible="false" fast="false">
        <listOfReactants><speciesReference species="iso" stoichiometry="1" constant="true"/></listOfReactants>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.1</cn><ci>iso</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_nar_prod" reversible="false" fast="false">
        <listOfProducts><speciesReference species="nar" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.5</cn><ci>ProdNar</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_nar_decay" reversible="false" fast="false">
        <listOfReactants><speciesReference species="nar" stoichiometry="1" constant="true"/></listOfReactants>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.1</cn><ci>nar</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_mal_prod" reversible="false" fast="false">
        <listOfProducts><speciesReference species="mal" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.5</cn><ci>ProdMal</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_mal_decay" reversible="false" fast="false">
        <listOfReactants><speciesReference species="mal" stoichiometry="1" constant="true"/></listOfReactants>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.1</cn><ci>mal</ci></apply>
        </math></kineticLaw>
      </reaction>

      <!-- ========== Nitrogen cycle strains (Monod x logistic) ========== -->
      <reaction id="r_NitroA_grow" reversible="false" fast="false">
        <listOfProducts><speciesReference species="NitroA" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/>
            <ci>mu</ci>
            <apply><divide/><ci>nh3</ci><apply><plus/><ci>K</ci><ci>nh3</ci></apply></apply>
            <ci>NitroA</ci>
            <apply><minus/><cn>1</cn><apply><divide/><ci>NitroA</ci><ci>K_pop</ci></apply></apply>
          </apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_NitroB_grow" reversible="false" fast="false">
        <listOfProducts><speciesReference species="NitroB" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/>
            <ci>mu</ci>
            <apply><divide/><ci>no2</ci><apply><plus/><ci>K</ci><ci>no2</ci></apply></apply>
            <ci>NitroB</ci>
            <apply><minus/><cn>1</cn><apply><divide/><ci>NitroB</ci><ci>K_pop</ci></apply></apply>
          </apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_Pseudo_grow" reversible="false" fast="false">
        <listOfProducts><speciesReference species="Pseudo" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/>
            <ci>mu</ci>
            <apply><divide/><ci>no3</ci><apply><plus/><ci>K</ci><ci>no3</ci></apply></apply>
            <ci>Pseudo</ci>
            <apply><minus/><cn>1</cn><apply><divide/><ci>Pseudo</ci><ci>K_pop</ci></apply></apply>
          </apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_Para_grow" reversible="false" fast="false">
        <listOfProducts><speciesReference species="Para" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/>
            <ci>mu</ci><ci>Para</ci>
            <apply><minus/><cn>1</cn><apply><divide/><ci>Para</ci><ci>K_pop</ci></apply></apply>
          </apply>
        </math></kineticLaw>
      </reaction>

      <!-- Nitrogen species dynamics (Nora) -->
      <!-- dnh3/dt = -0.5*NitroA + 0.2*Para -->
      <reaction id="r_nh3_cons" reversible="false" fast="false">
        <listOfReactants><speciesReference species="nh3" stoichiometry="1" constant="true"/></listOfReactants>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.5</cn><ci>NitroA</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_nh3_from_Para" reversible="false" fast="false">
        <listOfProducts><speciesReference species="nh3" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.2</cn><ci>Para</ci></apply>
        </math></kineticLaw>
      </reaction>

      <!-- dno2/dt = 0.5*NitroA - 0.5*NitroB - 0.1*no2 -->
      <reaction id="r_no2_prod" reversible="false" fast="false">
        <listOfProducts><speciesReference species="no2" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.5</cn><ci>NitroA</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_no2_cons" reversible="false" fast="false">
        <listOfReactants><speciesReference species="no2" stoichiometry="1" constant="true"/></listOfReactants>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.5</cn><ci>NitroB</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_no2_decay" reversible="false" fast="false">
        <listOfReactants><speciesReference species="no2" stoichiometry="1" constant="true"/></listOfReactants>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.1</cn><ci>no2</ci></apply>
        </math></kineticLaw>
      </reaction>

      <!-- dno3/dt = 0.5*NitroB - 0.4*Pseudo - 0.1*no3 -->
      <reaction id="r_no3_prod" reversible="false" fast="false">
        <listOfProducts><speciesReference species="no3" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.5</cn><ci>NitroB</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_no3_cons" reversible="false" fast="false">
        <listOfReactants><speciesReference species="no3" stoichiometry="1" constant="true"/></listOfReactants>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.4</cn><ci>Pseudo</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_no3_decay" reversible="false" fast="false">
        <listOfReactants><speciesReference species="no3" stoichiometry="1" constant="true"/></listOfReactants>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.1</cn><ci>no3</ci></apply>
        </math></kineticLaw>
      </reaction>

      <!-- ========== Cooperation (Geobacter) ========== -->
      <reaction id="r_GeoA_grow" reversible="false" fast="false">
        <listOfProducts><speciesReference species="GeoA" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/>
            <ci>mu</ci><ci>GeoA</ci>
            <apply><minus/><cn>1</cn><apply><divide/><ci>GeoA</ci><ci>K_pop</ci></apply></apply>
          </apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_GeoB_grow" reversible="false" fast="false">
        <listOfProducts><speciesReference species="GeoB" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/>
            <ci>mu</ci>
            <apply><divide/><ci>e</ci><apply><plus/><ci>K</ci><ci>e</ci></apply></apply>
            <ci>GeoB</ci>
            <apply><minus/><cn>1</cn><apply><divide/><ci>GeoB</ci><ci>K_pop</ci></apply></apply>
          </apply>
        </math></kineticLaw>
      </reaction>

      <!-- de/dt = 0.5*GeoA - 0.4*GeoB - 0.1*e -->
      <reaction id="r_e_prod" reversible="false" fast="false">
        <listOfProducts><speciesReference species="e" stoichiometry="1" constant="true"/></listOfProducts>
        <kineticLaw><math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply><times/><cn>0.5</cn><ci>GeoA</ci></apply>
        </math></kineticLaw>
      </reaction>

      <reaction id="r_e_cons" reversible="false" fast="false">
